# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
/dist
/tmp
/out-tsc
/docs
/vscode
# Only exists if Bazel was run
/bazel-out
.angular/

# dependencies
/node_modules

# Capacitor builds
/android
/ios
/www

# Lock files (usando pnpm, ignorar npm lock)
package-lock.json

# profiling files
chrome-profiler-events*.json

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# Environment files with secrets (local dev)
# NOTA: environment.prod.ts SÍ se versiona porque las API keys
# están restringidas por dominio en Google Cloud Console
src/environments/environment.ts
src/app/shared/docs

# Vercel
.vercel

# Firebase (opcional - debug logs)
firebase-debug.log
firebase-debug.*.log
.firebase/

# Capacitor local config
/android/local.properties
/android/.gradle/
/android/app/build/
/android/build/
