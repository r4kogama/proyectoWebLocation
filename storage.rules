rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // FUNCIONES DE AUTENTICACIÓN
    // ============================================

    // Función para verificar si el usuario está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Función para verificar si el usuario actual coincide con el ID del documento
    function isCurrentUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Función para obtener los datos existentes del documento
    function existingData() {
      return resource.data;
    }

    // Función para obtener los datos entrantes en la solicitud
    function incomingData() {
      return request.resource.data;
    }

    // ============================================
    // FUNCIONES DE VALIDACIÓN DE DATOS
    // ============================================

    // Verifica que un campo exista y sea un string no vacío
    function isNonEmptyString(field) {
      return field is string && field.size() > 0;
    }

    // Verifica que un campo sea booleano y sea true
    function isTrueBoolean(field) {
      return field is bool && field == true;
    }

    // Valida los campos requeridos para crear un usuario
    function isValidUserData() {
      let data = incomingData();
      return data.keys().hasAll(['name', 'email', 'terms'])
        && isNonEmptyString(data.name)
        && data.name.size() <= 15
        && data.name.matches('^[A-Za-z ]+$')
        && isNonEmptyString(data.email)
        && data.email.matches('.*@.*[.].*')
        && isTrueBoolean(data.terms);
    }

    // ============================================
    // REGLAS DE COLECCIÓN: USERS
    // ============================================

    match /users/{userId} {

      // PERMISOS DE LECTURA
      // 1. Permite consultas (list) a cualquiera (para la verificación de email).
      allow list: if true;

      // 2. Permite la lectura individual (get) solo al propietario.
      allow get: if isCurrentUser(userId);

      // PERMISOS DE ESCRITURA
      // 3. Crear: solo el propietario + validar campos requeridos
      allow create: if isCurrentUser(userId) && isValidUserData();

      // 4. Actualizar: solo el propietario + validar campos requeridos
      allow update: if isCurrentUser(userId) && isValidUserData();

      // 5. Eliminar: solo el propietario
      allow delete: if isCurrentUser(userId);
    }
  }
}
